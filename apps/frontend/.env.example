# Frontend environment variables.
#
# Local development uses .env.development (committed) — you don't need to copy
# this file for localhost. These are the variables to set for a production build.

# Public base URL of the deployed site. Feeds canonical URLs, Open Graph tags,
# the sitemap and robots.txt. Falls back to the production domain if unset.
NEXT_PUBLIC_SITE_URL=https://wotermark.jarza.cc

# Dev-only: origin that `next dev` proxies /api/* to. Not used by the static
# production build (your reverse proxy / Cloudflare serves /api in production).
BACKEND_ORIGIN=http://localhost:8080

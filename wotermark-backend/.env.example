# Port the API server listens on (default 8080)
PORT=8080

# Webhook the contact form forwards submissions to. Use an IFTTT Maker webhook
# (https://maker.ifttt.com/trigger/<event>/with/key/<key>) wired to a
# "Webhooks -> Email" applet, or any service that accepts a JSON POST with
# value1 (name), value2 (email), value3 (message). Leave empty to disable the
# contact form (the endpoint returns 503).
CONTACT_WEBHOOK_URL=
